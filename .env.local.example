# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://yourorg.atlassian.net
NEXT_PUBLIC_JIRA_BASE_URL=https://yourorg.atlassian.net   # REQUIRED for Vercel — baked into client bundle
JIRA_EMAIL=you@yourorg.com
JIRA_API_TOKEN=                           # from id.atlassian.com → Security → API tokens
JIRA_PROJECT_KEYS=DESIGN,PLATFORM         # comma-separated project keys
JIRA_HANDOVER_FIELD=                      # optional: custom field ID e.g. customfield_10234
JIRA_ACCOUNT_ID=                          # optional: auto-detected if blank

# ── Slack ──────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...                  # from api.slack.com/apps → OAuth & Permissions
SLACK_CHANNEL_IDS=C012345,C067890         # comma-separated channel IDs
SLACK_MY_USER_ID=U012345678              # your Slack member ID (for mention filtering)

# ── Figma ──────────────────────────────────────────────────────────────────────
FIGMA_ACCESS_TOKEN=figd_...              # from figma.com → Settings → Security → Personal access tokens
FIGMA_TEAM_IDS=123456789                  # comma-separated numeric team IDs
FIGMA_MY_HANDLE=Your Name                # your display name in Figma (for mention detection)
FIGMA_FILE_KEYS=                          # optional: comma-separated file keys to scan directly

# ── Canva (OAuth 2.0 + PKCE) ──────────────────────────────────────────────────
# Create integration at developers.canva.com
# Required scopes: design:meta:read, comment:read, profile:read
# Redirect URI must use 127.0.0.1, not localhost
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=http://127.0.0.1:3000/api/auth/canva/callback

# ── Google Calendar (OAuth 2.0) ────────────────────────────────────────────────
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Enable the Google Calendar API in your project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/api/auth/google/callback

# ── AI (optional) ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                        # for AI chat panel (claude-3-5-haiku)
OPENAI_API_KEY=                           # for thread summaries and smart replies (gpt-4o-mini)

# ── Auth (optional) ───────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=                       # set to enable login gate (leave blank for local dev)
